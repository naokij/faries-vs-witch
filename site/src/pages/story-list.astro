---
import Base from '~/layouts/Base.astro';
import { episodes } from '~/data/episodes';
---
<Base title="故事列表 · 仙子大战女巫" active="list">
  <main class="page page--wide">
    <header class="section">
      <div class="flex-between" style="flex-wrap: wrap; gap: var(--s-3);">
        <div>
          <span class="tag tag--accent"><span class="tag__dot"></span>故事小屋</span>
          <h1 style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 48px);">每一集都是一晚的睡前故事</h1>
          <p class="text-muted mt-2" style="font-size: 16px;">已上线 {episodes.filter(e => e.status === 'online').length} 集，由6岁的小橘子口述创作，爸爸记录整理。</p>
        </div>
        <div class="flex gap-2">
          <button class="tab" aria-pressed="true" data-filter="all">全部 · {episodes.length}</button>
          <button class="tab" aria-pressed="false" data-filter="online">已上线 · {episodes.filter(e => e.status === 'online').length}</button>
          <button class="tab" aria-pressed="false" data-filter="soon">敬请期待</button>
        </div>
      </div>
    </header>

    <section class="section">
      <div class="grid grid--3" id="episode-grid">
        {episodes.map(ep => {
          return (
          <article class="card episode-card" data-status={ep.status} data-color={ep.color}>
            <a href={`/story/${ep.slug}`} class="card__media-link">
              <div class="card__media" style="aspect-ratio: 1/1;">
                <img src={ep.cover} alt={ep.title + '封面'} loading="lazy" />
              </div>
            </a>
            <div class="card__body episode-card__body">
              <div class="episode-card__head">
                <div class="card__info">
                  <span class={`tag ${ep.status === 'online' ? 'tag--accent' : 'tag--soon'}`}>EP.{String(ep.number).padStart(2, '0')}</span>
                </div>
                <h3 class="card__title">{ep.title}</h3>
                <p class="card__meta">{ep.subtitle} · {ep.duration}</p>
              </div>
              <div class="card__cta">
                {ep.status === 'online' ? (
                  <a href={`/story/${ep.slug}`} class="btn btn--primary btn--sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    听
                  </a>
                ) : (
                  <button class="btn btn--ghost btn--sm" disabled style="opacity: 0.5; cursor: not-allowed;">尚未上线</button>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
    </section>

    <nav class="pagination" id="pagination" aria-label="分页导航"></nav>

    </main>

  <script>
    const PER_PAGE = 9;
    const grid = document.getElementById('episode-grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.episode-card'));
    const pagination = document.getElementById('pagination')!;

    let currentFilter = 'all';
    let currentPage = 1;

    function visibleCards() {
      return cards.filter(c => currentFilter === 'all' || c.dataset.status === currentFilter);
    }

    function totalPages() {
      return Math.max(1, Math.ceil(visibleCards().length / PER_PAGE));
    }

    function render() {
      const pages = totalPages();
      if (currentPage > pages) currentPage = pages;

      const start = (currentPage - 1) * PER_PAGE;
      const pageCards = visibleCards();
      const inPage = new Set(pageCards.slice(start, start + PER_PAGE));

      cards.forEach(card => {
        card.style.display = inPage.has(card) ? '' : 'none';
      });

      // 构建分页按钮
      const btns: string[] = [];
      btns.push(`<button class="pagination__btn" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>`);
      for (let p = 1; p <= pages; p++) {
        btns.push(`<button class="pagination__num ${p === currentPage ? 'is-active' : ''}" data-page="${p}">${p}</button>`);
      }
      btns.push(`<button class="pagination__btn" data-page="${currentPage + 1}" ${currentPage === pages ? 'disabled' : ''}>下一页</button>`);
      pagination.innerHTML = btns.join('');
    }

    // 分页点击
    pagination.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-page]') as HTMLElement | null;
      if (!btn || btn.hasAttribute('disabled')) return;
      const page = Number(btn.dataset.page);
      if (page < 1 || page > totalPages()) return;
      currentPage = page;
      render();
      grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // 筛选点击
    document.querySelectorAll<HTMLButtonElement>('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>('.tab').forEach(t => t.setAttribute('aria-pressed', t === tab ? 'true' : 'false'));
        currentFilter = tab.dataset.filter || 'all';
        currentPage = 1;
        render();
      });
    });

    render();
  </script>
</Base>