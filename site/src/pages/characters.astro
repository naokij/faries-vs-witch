---
import Base from '~/layouts/Base.astro';
import CharacterPortrait from '~/components/CharacterPortrait.astro';
import { allCharacters, roleLabelMap } from '~/data/characters';
import { episodes, getEpisodeBySlug } from '~/data/episodes';

const total = allCharacters.length;
const groups = {
  leader: allCharacters.filter(c => c.role === 'leader'),
  baby: allCharacters.filter(c => c.role === 'baby'),
  warrior: allCharacters.filter(c => c.role === 'warrior'),
  witch: allCharacters.filter(c => c.role === 'witch'),
  ally: allCharacters.filter(c => c.role === 'ally'),
};

// 出场剧集映射: charId -> [{ slug, title, number }]
const epsByCharId: Record<string, { slug: string; title: string; number: number }[]> = {};
for (const c of allCharacters) {
  epsByCharId[c.id] = episodes
    .filter((ep) => ep.charactersInScene.includes(c.id) && ep.status === 'online')
    .map((ep) => ({ slug: ep.slug, title: ep.title, number: ep.number }));
}
const epsDataJson = JSON.stringify(epsByCharId);
---
<Base title="人物介绍 · 仙子大战女巫" active="characters">
  <main class="page page--wide">
    <header class="section">
      <span class="tag tag--accent"><span class="tag__dot"></span>森林仙子村 · 名册</span>
      <h1 style="margin-top: var(--s-2); font-size: clamp(32px, 5vw, 48px);">认识仙子们</h1>
      <p class="text-muted mt-2" style="font-size: 16px; max-width: 60ch;">
        {total} 位角色：1 位仙子首领、3 位宝宝仙子、5 位小勇士、{groups.ally.length} 位新伙伴、{groups.witch.length} 位反派。点击卡片看完整档案。
      </p>
    </header>

    <section class="section" data-filter-scope>
      <div class="tabs">
        <button class="tab" aria-pressed="true" data-filter="all">全部 · {total}</button>
        <button class="tab" aria-pressed="false" data-filter="leader">{roleLabelMap.leader} · {groups.leader.length}</button>
        <button class="tab" aria-pressed="false" data-filter="baby">{roleLabelMap.baby} · {groups.baby.length}</button>
        <button class="tab" aria-pressed="false" data-filter="warrior">{roleLabelMap.warrior} · {groups.warrior.length}</button>
        <button class="tab" aria-pressed="false" data-filter="witch">{roleLabelMap.witch} · {groups.witch.length}</button>
        <button class="tab" aria-pressed="false" data-filter="ally">{roleLabelMap.ally} · {groups.ally.length}</button>
      </div>

      <div class="grid grid--characters" id="char-grid">
        {allCharacters.map(c => (
          <article
            class="character-card"
            id={`char-${c.id}`}
            data-color={c.color}
            data-name={c.name}
            data-role={c.role}
            data-role-label={c.roleLabel}
            data-age={c.age}
            data-power={c.power}
            data-bio={c.bio}
            data-portrait={c.portrait}
          >
            <div class="character-card__portrait">
              <CharacterPortrait portrait={c.portrait} name={c.name} />
            </div>
            <div class="character-card__name">{c.name}</div>
            <div class="character-card__role">{c.roleLabel} · {c.age}</div>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="card" style="padding: var(--s-6); background: linear-gradient(135deg, oklch(96% 0.025 320), oklch(96% 0.020 80));">
        <h3 style="margin-bottom: var(--s-3);">人物关系（一句话版）</h3>
        <p class="text-muted" style="font-size: 15px; line-height: 1.85; max-width: 64ch;">
          <strong>阿玛利亚</strong>是妈妈，<strong>梦梦 / 苗苗 / 悠悠</strong>是她的三个宝宝女儿；
          <strong>月月 / 境境 / 蓉蓉 / 冰冰 / 火火</strong>是保护她的 5 位小勇士，每位都有自己的搭档（冰冰+蓉蓉是天生搭档）。
          她们的对手是<strong>巫巫女</strong>——住在黑暗城堡里的女巫，把光明之心偷走变成黑暗核心。
        </p>
      </div>
    </section>
  </main>

  <script id="eps-data" type="application/json" set:html={epsDataJson} />

  <div class="modal" id="character-modal" aria-hidden="true" role="dialog" aria-labelledby="modal-name">
    <div class="modal__panel" role="document">
      <button class="modal__close" aria-label="关闭">×</button>
      <div class="modal__grid">
        <div class="modal__hero">
          <img src="" alt="" id="modal-img" />
        </div>
        <div class="modal__info">
          <span id="modal-role" class="tag"><span class="tag__dot"></span></span>
          <h3 class="modal__name" id="modal-name">角色名</h3>
          <dl id="modal-rows"></dl>
          <p class="modal__bio" id="modal-bio"></p>
          <div class="modal__appearances">
            <h4>出场剧集</h4>
            <ul id="modal-episodes"></ul>
          </div>
        </div>
      </div>
      <div class="modal__nav">
        <button class="modal__nav-btn" id="modal-prev" aria-label="上一个角色">← 上一个</button>
        <span class="modal__counter" id="modal-counter">— / —</span>
        <button class="modal__nav-btn" id="modal-next" aria-label="下一个角色">下一个 →</button>
      </div>
    </div>
  </div>

  <script>
    // 角色筛选
    document.querySelectorAll<HTMLButtonElement>('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll<HTMLButtonElement>('.tab').forEach(t => t.setAttribute('aria-pressed', t === tab ? 'true' : 'false'));
        const filter = tab.dataset.filter || 'all';
        document.querySelectorAll<HTMLElement>('#char-grid .character-card').forEach(card => {
          const role = card.dataset.role || '';
          card.style.display = (filter === 'all' || role === filter) ? '' : 'none';
        });
      });
    });

    // 角色详情模态 (双栏 + 大图 + 出场列表 + 上下导航)
    (function () {
      const modal = document.getElementById('character-modal') as HTMLDivElement;
      if (!modal) return;
      const imgEl = document.getElementById('modal-img') as HTMLImageElement;
      const nameEl = document.getElementById('modal-name') as HTMLHeadingElement;
      const roleEl = document.getElementById('modal-role') as HTMLSpanElement;
      const bioEl = document.getElementById('modal-bio') as HTMLParagraphElement;
      const rowsEl = document.getElementById('modal-rows') as HTMLDListElement;
      const epsEl = document.getElementById('modal-episodes') as HTMLUListElement;
      const counterEl = document.getElementById('modal-counter') as HTMLSpanElement;
      const prevBtn = document.getElementById('modal-prev') as HTMLButtonElement;
      const nextBtn = document.getElementById('modal-next') as HTMLButtonElement;
      const closeBtn = modal.querySelector('.modal__close') as HTMLButtonElement;

      // 可见卡片数组(列表顺序,不含被筛掉的)
      const cardsArr: HTMLElement[] = Array.from(
        document.querySelectorAll<HTMLElement>('#char-grid .character-card')
      );

      // 出场剧集数据 (来自 SSR 内联 JSON)
      type EpInfo = { slug: string; title: string; number: number };
      const epsByCharId: Record<string, EpInfo[]> = (() => {
        const el = document.getElementById('eps-data');
        if (!el) return {};
        try { return JSON.parse(el.textContent || '{}'); } catch { return {}; }
      })();

      let currentIdx = -1;

      function cardData(card: HTMLElement) {
        return {
          id: card.id.replace(/^char-/, ''),
          name: card.dataset.name || '',
          role: card.dataset.role || '',
          roleLabel: card.dataset.roleLabel || '',
          age: card.dataset.age || '',
          power: card.dataset.power || '',
          bio: card.dataset.bio || '',
          portrait: card.dataset.portrait || '',
          color: card.dataset.color || '',
        };
      }

      function escHtml(s: string): string {
        return s.replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        } as Record<string, string>)[c] as string);
      }

      function render(idx: number) {
        if (idx < 0 || idx >= cardsArr.length) return;
        currentIdx = idx;
        const card = cardsArr[idx];
        const d = cardData(card);

        // 大图 srcset
        const stem = d.portrait.replace(/\.jpg$/i, '');
        imgEl.src = d.portrait;
        imgEl.srcset = `${stem}-400.jpg 400w, ${stem}-800.jpg 800w, ${d.portrait} 2048w`;
        imgEl.sizes = '(max-width: 720px) 90vw, 360px';
        imgEl.alt = d.name;

        // 角色 + 类型 tag
        nameEl.textContent = d.name;
        roleEl.className = 'tag tag--' + d.color;
        roleEl.innerHTML = '<span class="tag__dot"></span>' + escHtml(d.roleLabel);

        // 行(年龄 / 能力 / 登场于)
        const dataId = d.id;
        const eps = epsByCharId[dataId] || [];
        const debut = eps[0];
        rowsEl.innerHTML =
          '<div class="modal__row"><dt>年龄</dt><dd>' + escHtml(d.age || '—') + '</dd></div>' +
          '<div class="modal__row"><dt>能力</dt><dd>' + escHtml(d.power || '—') + '</dd></div>' +
          (debut
            ? '<div class="modal__row"><dt>初登场</dt><dd><a href="/story/' + debut.slug + '">EP.' + String(debut.number).padStart(2, '0') + ' · ' + escHtml(debut.title) + '</a></dd></div>'
            : '<div class="modal__row"><dt>初登场</dt><dd>—</dd></div>');

        bioEl.textContent = d.bio;

        // 出场剧集列表
        if (eps.length === 0) {
          epsEl.innerHTML = '<li class="modal__appearances-empty">尚未在已上线剧集中出场</li>';
        } else {
          epsEl.innerHTML = eps
            .map(
              (ep) =>
                '<li><a href="/story/' + escHtml(ep.slug) + '">' +
                '<span class="ep-num">EP.' + String(ep.number).padStart(2, '0') + '</span>' +
                '<span class="ep-title">' + escHtml(ep.title) + '</span></a></li>'
            )
            .join('');
        }

        // 计数 + 上下按钮状态
        counterEl.textContent = (idx + 1) + ' / ' + cardsArr.length;
        prevBtn.disabled = idx === 0;
        nextBtn.disabled = idx === cardsArr.length - 1;
      }

      function open(idx: number) {
        render(idx);
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function close() {
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        currentIdx = -1;
      }

      cardsArr.forEach((card, idx) => {
        card.addEventListener('click', () => open(idx));
      });

      prevBtn.addEventListener('click', () => {
        if (currentIdx > 0) open(currentIdx - 1);
      });
      nextBtn.addEventListener('click', () => {
        if (currentIdx < cardsArr.length - 1) open(currentIdx + 1);
      });

      closeBtn.addEventListener('click', close);
      modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
      document.addEventListener('keydown', (e) => {
        if (modal.getAttribute('aria-hidden') === 'true') return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft' && currentIdx > 0) open(currentIdx - 1);
        else if (e.key === 'ArrowRight' && currentIdx < cardsArr.length - 1) open(currentIdx + 1);
      });

      // URL hash 直接打开
      const hash = location.hash.slice(1);
      if (hash) {
        const targetIdx = cardsArr.findIndex((c) => c.id === hash);
        if (targetIdx >= 0) open(targetIdx);
      }
    })();
  </script>
</Base>