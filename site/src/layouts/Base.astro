---
import '~/styles/shared.css';
import { episodes } from '~/data/episodes';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'list' | 'characters';
}

const { title = '仙子大战女巫 · 森林仙子村有声绘本', description = '6岁女儿的睡前故事，森林仙子大战黑暗女巫的奇幻冒险。', active = 'home' } = Astro.props;
const onlineCount = episodes.filter(e => e.status === 'online').length;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#faf3e3" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="仙子大战女巫" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  </head>
  <body>
    <h1 class="visually-hidden">仙子大战女巫 — 森林仙子村睡前有声绘本</h1>

    <nav class="site-nav" data-od-id="site-nav">
      <a href="/" class="site-nav__brand">
        <span class="site-nav__brand-mark">仙</span>
        <span class="site-nav__brand-text">仙子大战女巫</span>
      </a>
      <div class="site-nav__links">
        <a href="/" class={`site-nav__link ${active === 'home' ? 'is-active' : ''}`} aria-current={active === 'home' ? 'page' : undefined}>首页</a>
        <a href="/story-list" class={`site-nav__link ${active === 'list' ? 'is-active' : ''}`} aria-current={active === 'list' ? 'page' : undefined}>故事列表</a>
        <a href="/characters" class={`site-nav__link ${active === 'characters' ? 'is-active' : ''}`} aria-current={active === 'characters' ? 'page' : undefined}>人物介绍</a>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <p>森林仙子村 · 仙子大战女巫</p>
      <p class="text-muted">由 6 岁的小橘子口述，爸爸记录整理 · 共 {onlineCount} 集有声绘本</p>
      <p class="text-muted" style="margin-top: 6px; font-size: 12px;">
        <a href="https://github.com/naokij/faries-vs-witch" target="_blank" rel="noopener" style="color: var(--muted); text-decoration: none;">GitHub →</a>
      </p>
    </footer>

    <script>
      // 角色卡颜色变量绑定（首页等使用 character-card 的页面）
      document.querySelectorAll<HTMLElement>('.character-card[data-color]').forEach(card => {
        const color = card.dataset.color;
        if (color) card.style.setProperty('--card-color', `var(--c-${color})`);
      });

      // 高亮当前导航
      const pathname = location.pathname.replace(/\/+$/, '') || '/';
      document.querySelectorAll<HTMLAnchorElement>('.site-nav__link').forEach(a => {
        const href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
        if (pathname === href || (href !== '/' && pathname.startsWith(href + '/'))) {
          a.classList.add('is-active');
          a.setAttribute('aria-current', 'page');
        } else {
          a.classList.remove('is-active');
          a.removeAttribute('aria-current');
        }
      });
    </script>
  </body>
</html>